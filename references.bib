@ARTICLE{Grosvenor2021-zl,
  title         = "{Space-dependent symmetries and fractons}",
  author        = "Grosvenor, Kevin T and Hoyos, Carlos and Pe\~{n}a-Benitez,
                   Francisco and Sur\'{o}wka, Piotr",
  journal       = "arXiv [hep-th]",
  abstract      = "There has been a surge of interest in effective
                   non-Lorentzian theories of excitations with restricted
                   mobility, known as fractons. Examples include defects in
                   elastic materials, vortex lattices or spin liquids. In the
                   effective theory novel coordinate-dependent symmetries emerge
                   that shape the properties of fractons. In this review we will
