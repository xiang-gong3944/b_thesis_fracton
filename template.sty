\tcbuselibrary{skins,breakable}
% =========================
% Thesis-friendly tcolorbox (NO theorem environments)
% =========================
\RequirePackage{xcolor} % 既にどこかで読んでいてもOK

% ---- テーマ切替（色を一括管理）----
\colorlet{TB@back}{white}
\colorlet{TB@frame}{black!45}
\colorlet{TB@titlebg}{black!10}

\newcommand{\ThesisBoxThemeMono}{%
  \colorlet{TB@back}{white}%
  \colorlet{TB@frame}{black!45}%
  \colorlet{TB@titlebg}{black!10}%
}
\newcommand{\ThesisBoxThemeBlue}{%
  \colorlet{TB@back}{white}%
  \colorlet{TB@frame}{blue!55!black}%
  \colorlet{TB@titlebg}{blue!10}%
}
\newcommand{\ThesisBoxThemeSepia}{%
  \colorlet{TB@back}{white}%
  \colorlet{TB@frame}{brown!60!black}%
  \colorlet{TB@titlebg}{brown!12}%
}

% デフォルトはセピア
\AtBeginDocument{\ThesisBoxThemeSepia}

% ---- 共通形状（論文っぽい控えめ設定）----
\tcbset{
  thesisbox/.style={
    enhanced,
    breakable,
    colback=TB@back,
    colframe=TB@frame,
    coltitle=black,
    fonttitle=\bfseries,
    boxrule=0.5pt,
    arc=1mm,
    boxsep=1.2mm,
    left=1.6mm,right=1.6mm,top=1.2mm,bottom=1.2mm,
    toptitle=0.8mm,bottomtitle=0.6mm,
    attach boxed title to top left={xshift=1.2mm,yshift*=-1mm},
    boxed title style={
      colback=TB@titlebg,
      boxrule=0pt,
      arc=0.8mm,
      left=1.0mm,right=1.0mm,top=0.6mm,bottom=0.6mm,
    },
  },
}

% ---- 使い分け用の箱（全部「番号なし」）----
\newtcolorbox{NoteBox}[2][]{thesisbox,title={#2},#1}

% 左に細線アクセント（「要点」向け）
\newtcolorbox{KeyBox}[2][]{%
  thesisbox,
  borderline west={2pt}{0pt}{TB@frame},
  title={#2},
  #1
}

% 注意・警告（背景ちょい濃い）
\newtcolorbox{WarnBox}[2][]{%
  thesisbox,
  colback=TB@back!70,
  title={#2},
  #1
}